generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

/// 用户账号
model User {
  /// 用户ID
  id                String            @id @default(cuid())
  /// 手机号（登录凭证）
  phone             String            @unique
  /// bcrypt 密码哈希
  passwordHash      String
  /// 昵称
  nickname          String
  /// 头像URL
  avatarUrl         String?
  /// 新记录默认可见性
  defaultVisibility DefaultVisibility @default(PRIVATE)
  /// 注册时间
  createdAt         DateTime          @default(now())
  /// 最后更新时间
  updatedAt         DateTime          @updatedAt
  comments          Comment[]
  matchesB          Match[]           @relation("MatchUserB")
  matchesA          Match[]           @relation("MatchUserA")
  memoryHookLikes   MemoryHookLike[]
  repos             Repo[]
  repoLikes         RepoLike[]
  reportsFiled      Report[]          @relation("Reporter")
  showInterests     ShowInterest[]
  blockedBy         UserBlock[]       @relation("Blocked")
  blockedUsers      UserBlock[]       @relation("Blocker")
  memories          Memory[]
}

/// 现场记忆（轻量情绪快照）
model Memory {
  /// 记忆ID
  id         String          @id @default(cuid())
  /// 发布者
  userId     String
  /// 绑定的演出
  showId     String
  /// 文字内容（无字数/格式限制）
  text       String?
  /// 可见性
  visibility RepoVisibility  @default(PUBLIC)
  /// 发布时间
  createdAt  DateTime        @default(now())
  /// 关联
  user       User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  show       Show            @relation(fields: [showId], references: [id], onDelete: Cascade)
  media      MemoryMedia[]

  @@unique([userId, showId])
  @@index([showId, visibility])
}

/// 记忆媒体（照片/视频/录音）
model MemoryMedia {
  /// 媒体ID
  id         String    @id @default(cuid())
  /// 所属记忆
  memoryId   String
  /// 文件访问URL
  url        String
  /// 文件类型
  type       MediaType @default(IMAGE)
  /// 排序序号
  sortOrder  Int       @default(0)
  /// 上传时间
  createdAt  DateTime  @default(now())
  /// 关联
  memory     Memory    @relation(fields: [memoryId], references: [id], onDelete: Cascade)

  @@index([memoryId])
}

/// 用户拉黑关系（A拉黑B后，双方互不可见）
model UserBlock {
  /// 关系ID
  id        String   @id @default(cuid())
  /// 拉黑者ID
  blockerId String
  /// 被拉黑者ID
  blockedId String
  /// 拉黑时间
  createdAt DateTime @default(now())
  blocked   User     @relation("Blocked", fields: [blockedId], references: [id], onDelete: Cascade)
  blocker   User     @relation("Blocker", fields: [blockerId], references: [id], onDelete: Cascade)

  @@unique([blockerId, blockedId])
  @@index([blockerId])
}

/// 演出条目（唯一约束：同一艺人同一天同一场馆不重复）
model Show {
  /// 演出ID
  id          String         @id @default(cuid())
  /// 艺人/乐队名
  artistName  String
  /// 场馆名（如 MAO Livehouse）
  venueName   String
  /// 演出日期时间
  showDate    DateTime
  /// 城市
  city        String?
  /// 描述/备注
  description String?
  /// 创建时间
  createdAt   DateTime       @default(now())
  /// 最后更新时间
  updatedAt   DateTime       @updatedAt
  matches     Match[]
  repos       Repo[]
  interests   ShowInterest[]
  memories    Memory[]

  @@unique([artistName, venueName, showDate])
  @@index([showDate])
  @@index([artistName])
  @@index([venueName])
}

/// 用户对演出的兴趣标记（想看/看过）
model ShowInterest {
  /// 关系ID
  id        String           @id @default(cuid())
  /// 用户ID
  userId    String
  /// 演出ID
  showId    String
  /// 兴趣类型
  type      ShowInterestType
  /// 标记时间
  createdAt DateTime         @default(now())
  show      Show             @relation(fields: [showId], references: [id], onDelete: Cascade)
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, showId, type])
  @@index([showId, type])
}

/// 现场记录（Repo）—— 用户为某场演出写的记忆
model Repo {
  /// 记录ID
  id                  String           @id @default(cuid())
  /// 作者ID
  userId              String
  /// 所属演出ID
  showId              String
  /// 正文内容（可选）
  body                String?
  /// 一句话记忆（必填，≤20字）
  memoryHook          String
  /// 记忆模板类型 A/B/C/D
  memoryTemplate      String?
  /// 记忆点赞数（冗余计数器）
  memoryHookLikeCount Int              @default(0)
  /// 乐队表现评分 1-5
  vibeBand            Int
  /// 音响效果评分 1-5
  vibeSound           Int
  /// 现场氛围评分 1-5
  vibeAtmosphere      Int
  /// 可见性（默认仅自己）
  visibility          RepoVisibility   @default(PRIVATE)
  /// 点赞数（冗余计数器）
  likeCount           Int              @default(0)
  /// 评论数（冗余计数器）
  commentCount        Int              @default(0)
  /// 发布时间
  createdAt           DateTime         @default(now())
  /// 最后修改时间
  updatedAt           DateTime         @updatedAt
  comments            Comment[]
  memoryHookLikes     MemoryHookLike[]
  show                Show             @relation(fields: [showId], references: [id], onDelete: Cascade)
  user                User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  likes               RepoLike[]
  media               RepoMedia[]

  @@index([userId, createdAt])
  @@index([showId, visibility, createdAt])
  @@index([showId, visibility, likeCount])
  @@index([showId, memoryHook, visibility])
}

/// Repo 关联的媒体文件
model RepoMedia {
  /// 媒体ID
  id        String    @id @default(cuid())
  /// 所属RepoID
  repoId    String
  /// 文件访问URL
  url       String
  /// 文件类型
  type      MediaType @default(IMAGE)
  /// 照片标签 JSON 数组
  tags      String    @default("[]")
  /// 排列序号（从小到大）
  sortOrder Int       @default(0)
  /// 上传时间
  createdAt DateTime  @default(now())
  repo      Repo      @relation(fields: [repoId], references: [id], onDelete: Cascade)

  @@index([repoId])
}

/// 点赞记录
model RepoLike {
  /// 点赞ID
  id        String   @id @default(cuid())
  /// 点赞者ID
  userId    String
  /// 被点赞的RepoID
  repoId    String
  /// 点赞时间
  createdAt DateTime @default(now())
  repo      Repo     @relation(fields: [repoId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, repoId])
  @@index([repoId])
}

/// 一句话记忆点赞
model MemoryHookLike {
  /// 点赞ID
  id        String   @id @default(cuid())
  /// 点赞者ID
  userId    String
  /// 被点赞的RepoID
  repoId    String
  /// 点赞时间
  createdAt DateTime @default(now())
  repo      Repo     @relation(fields: [repoId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, repoId])
  @@index([repoId])
}

/// 评论
model Comment {
  /// 评论ID
  id        String    @id @default(cuid())
  /// 所属RepoID
  repoId    String
  /// 评论者ID
  userId    String
  /// 评论内容
  body      String
  /// 回复目标评论ID（null=直接评论）
  parentId  String?
  /// 评论时间
  createdAt DateTime  @default(now())
  /// 最后修改时间
  updatedAt DateTime  @updatedAt
  parent    Comment?  @relation("CommentReply", fields: [parentId], references: [id])
  replies   Comment[] @relation("CommentReply")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  repo      Repo      @relation(fields: [repoId], references: [id], onDelete: Cascade)

  @@index([repoId, createdAt])
  @@index([parentId])
}

/// 举报记录
model Report {
  /// 举报ID
  id         String           @id @default(cuid())
  /// 举报人ID
  reporterId String
  /// 举报目标类型
  targetType ReportTargetType
  /// 举报目标ID
  targetId   String
  /// 举报原因
  reason     String
  /// 处理状态
  status     ReportStatus     @default(PENDING)
  /// 举报时间
  createdAt  DateTime         @default(now())
  /// 最后处理时间
  updatedAt  DateTime         @updatedAt
  reporter   User             @relation("Reporter", fields: [reporterId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([targetType, targetId])
}

/// 上传文件资产（记录上传文件元信息）
model MediaAsset {
  /// 资产ID
  id           String   @id @default(cuid())
  /// 上传者ID
  uploaderId   String
  /// 原始文件名
  originalName String
  /// MIME类型（如 image/jpeg）
  mimeType     String
  /// 文件大小（字节）
  sizeBytes    Int
  /// 本地存储路径
  storagePath  String
  /// 公开访问URL
  publicUrl    String
  /// 上传时间
  createdAt    DateTime @default(now())

  @@index([uploaderId])
}

/// 共同记忆匹配记录
model Match {
  /// 匹配ID
  id              String      @id @default(cuid())
  /// 用户A
  userAId         String
  /// 用户B
  userBId         String
  /// 撞上的演出ID
  showId          String
  /// 匹配层级 1/2/3
  matchLevel      Int
  /// 审美重合度 (0-100)
  similarityScore Float?
  /// A的一句话记忆
  memoryHookA     String?
  /// B的一句话记忆
  memoryHookB     String?
  /// 匹配时间
  matchedAt       DateTime    @default(now())
  /// A最近查看时间（盲盒用）
  lastSeenAt      DateTime?
  /// 状态
  status          MatchStatus @default(PENDING)
  show            Show        @relation(fields: [showId], references: [id], onDelete: Cascade)
  userB           User        @relation("MatchUserB", fields: [userBId], references: [id], onDelete: Cascade)
  userA           User        @relation("MatchUserA", fields: [userAId], references: [id], onDelete: Cascade)

  @@unique([userAId, userBId, showId])
  @@index([userAId, status])
  @@index([userBId, status])
  @@index([showId])
}

/// 用户默认可见性
enum DefaultVisibility {
  /// 仅自己
  PRIVATE
  /// 公开到演出条目
  PUBLIC_TO_SHOW
}

/// Repo 现场记录可见性
enum RepoVisibility {
  /// 仅自己
  PRIVATE
  /// 公开到条目记忆墙
  PUBLIC
}

/// 用户对演出的兴趣类型
enum ShowInterestType {
  /// 想看
  WANT_TO_SEE
  /// 看过
  ATTENDED
}

/// 媒体文件类型
enum MediaType {
  /// 图片
  IMAGE
  /// 视频
  VIDEO
  /// 录音
  AUDIO
}

/// 举报目标类型
enum ReportTargetType {
  /// 举报现场记录
  REPO
  /// 举报评论
  COMMENT
  /// 举报用户
  USER
}

/// 举报处理状态
enum ReportStatus {
  /// 待处理
  PENDING
  /// 已解决
  RESOLVED
  /// 已驳回
  REJECTED
}

/// 匹配状态
enum MatchStatus {
  /// 待处理（用户尚未回应）
  PENDING
  /// 已建立连接
  CONNECTED
  /// 已忽略
  DISMISSED
}
